# ============================================================================
# BLACK ROCOCO — environment configuration
#
# SINGLE-SALON PRODUCT. One deployment serves exactly one salon, resolved once
# at boot. Nothing here is per-request and no client input can select a salon.
# ============================================================================

PORT=3000
NODE_ENV=production

# ---- Admin login -----------------------------------------------------------
# The single admin account. There is no user table: these ARE the credentials.
# CHANGE THE PASSWORD before deploying. It is never printed to the logs.
ADMIN_EMAIL=admin@blackrococo.mx
ADMIN_PASSWORD=change-this-before-deploying

# ---- Database (Supabase) ---------------------------------------------------
# Leave BOTH blank to run against the local data/db.json file (dev mode).
# Set BOTH to persist to Postgres (production).
#
# Setup, in order:
#   1. Run sql/schema.sql in the Supabase SQL editor.
#   2. Run every file in sql/migrations/ in filename order.
#   3. Confirm the `salons` table has a row whose `slug` matches SALON_SLUG below.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# REQUIRED when Supabase is configured.
#
# Identifies WHICH row in the `salons` table this deployment serves. It is read
# ONCE at startup. If no active salon has this slug, the server refuses to start
# with a clear error rather than running against nothing.
#
# This must match the `slug` column of your salon row exactly.
SALON_SLUG=nails

# Signs admin session tokens. REQUIRED in production.
# Without it, a temporary secret is generated per run, so every restart /
# redeploy silently logs every admin out.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ---- Storage ---------------------------------------------------------------
# Supabase Storage bucket for uploaded photos and video. Create it once and set
# it to PUBLIC, or every image upload will fail. The server verifies this at
# boot and logs a clear warning if it is missing or private.
SUPABASE_STORAGE_BUCKET=media

# ---- Public site -----------------------------------------------------------
# The live URL, e.g. https://blackrococo.up.railway.app
#
# Used to build absolute og:image / canonical URLs. Social scrapers (WhatsApp,
# Facebook, Instagram) fetch the preview image directly and do NOT run
# JavaScript, so if this is wrong the link preview will be blank. If left empty
# the server falls back to the request's own Host, which is usually correct.
SITE_URL=

# ---- Business locale -------------------------------------------------------
# Used for reminders and Google Calendar. BUSINESS_TZ_OFFSET must match
# BUSINESS_TIME_ZONE, and is what stops a UTC server from thinking a 9am
# Guadalajara slot is already in the past.
BUSINESS_TIME_ZONE=America/Mexico_City
BUSINESS_TZ_OFFSET=-06:00
DEFAULT_COUNTRY_DIAL_CODE=521

# ---- Integrations (all optional) -------------------------------------------
# Each is a webhook (Make / Zapier / n8n / custom). Leave blank to disable; the
# feature degrades quietly and the admin panel shows it as "pending setup".

# Fired on every new booking.
BOOKING_WEBHOOK_URL=

# Creates a Google Calendar event for each booking.
GOOGLE_CALENDAR_WEBHOOK_URL=

# Sends the owner a WhatsApp alert on each booking.
WHATSAPP_ADMIN_WEBHOOK_URL=
WHATSAPP_ADMIN_PHONE=5213326553522

# Automatic client reminders, N hours before the appointment.
CLIENT_REMINDER_WEBHOOK_URL=
CLIENT_REMINDER_HOURS=24,2

# ---- Google Calendar OAuth (optional) --------------------------------------
# Direct Google Calendar integration, as an alternative to the webhook above.
# Set up at https://console.cloud.google.com -> Credentials -> OAuth client ID
# (type: Web application).
#
# The redirect URI must be registered in the Google console EXACTLY as it
# appears here. If left blank it is derived from SITE_URL.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# ---- Advanced (rarely changed) ---------------------------------------------
# Path to the local JSON database. Only used in dev mode (no Supabase).
DB_PATH=data/db.json

# NOTE: RAILWAY_ENVIRONMENT is set automatically by Railway. Do not set it
# yourself. The app uses it (alongside NODE_ENV) to decide it is in production,
# which turns on the Secure cookie flag and silences development-only logging.
